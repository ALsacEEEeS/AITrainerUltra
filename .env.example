# AITrainerUltra Environment Configuration
# Copy this file to .env and adjust values for your setup.

# --- Server ---

# API Key for optional authentication.
# If set, all /api/* requests must include X-API-Key header with this value.
AITRAINER_API_KEY=

# Debug mode. Set to "1" or "true" to enable detailed error messages.
AITRAINER_DEBUG=false

# Override the frontend static files directory.
# Default: auto-detected (frontend/dist, PyInstaller bundle, etc.)
AITRAINER_STATIC_DIR=

# CORS allowed origins. Comma-separated list of origins.
# Default: * (allow all). For production, set to your domain(s).
# Example: https://myapp.com,https://app.example.com
AITRAINER_CORS_ORIGINS=*

# Host to bind the server to.
AITRAINER_HOST=127.0.0.1

# Port to run the server on.
AITRAINER_PORT=8000

# --- GPU / Compute ---

# CUDA visible devices (Docker / multi-GPU).
# Example: "0" (first GPU), "0,1" (first two GPUs)
CUDA_VISIBLE_DEVICES=

# --- Frontend ---

# API URL for frontend development server.
VITE_API_URL=http://localhost:8000
